{
  "name": "observability",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:generate-pg": "drizzle-kit generate --config drizzle.config.postgres.ts",
    "db:migrate-sqlite-to-pg": "tsx scripts/sqlite-to-postgres.ts",
    "db:normalize-alert-market-scope": "tsx scripts/normalize-alert-rule-market-scopes.ts",
    "otel:collector": "docker compose -f docker-compose.otel.yml up",
    "otel:collector:detach": "docker compose -f docker-compose.otel.yml up -d",
    "otel:collector:stop": "docker compose -f docker-compose.otel.yml down"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@tanstack/react-virtual": "^3.13.24",
    "ai": "^6.0.174",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "long": "^5.3.2",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "protobufjs": "^8.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/long": "^4.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
