# Copy this file to ".env" (same folder), then edit the secret below.
# Command (Mac / Linux):  cp .env.example .env
# Windows (PowerShell):   Copy-Item .env.example .env

# Shared secret: Pulse and the collector both use this value.
# Pick any long random phrase you like (you will not type it often).
PULSE_INGEST_API_KEY=replace-this-with-your-own-secret

# Address of Pulse inside Docker (usually leave this as-is on Mac/Windows).
# Linux: if telemetry never appears, try http://172.17.0.1:3000/api/v1/ingest/otlp
PULSE_OTLP_ENDPOINT=http://host.docker.internal:3000/api/v1/ingest/otlp

# Optional — powers natural-language query + AI Ops brief (Executive Briefing page).
# OPENAI_API_KEY=
# OPENAI_OPS_BRIEF_MODEL=gpt-4o-mini
# Optional — default tenant when header/cookie absent (single-tenant installs).
# PULSE_DEFAULT_TENANT_ID=default

# SaaS: require every ingest request to send x-pulse-tenant-id (see START_HERE or health JSON).
# PULSE_MULTI_TENANT=1

# Inline retention guardrail (runs after ingest when cron may miss). Interval in ms (default 6h).
# PULSE_DISABLE_INLINE_RETENTION=1
# PULSE_RETENTION_INLINE_INTERVAL_MS=21600000
